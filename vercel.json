{
    "version": 2,
    "builds": [
        {
            "src": "Src/scripts/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "Src/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/Src/scripts/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/Src/$1"
        }
    ]
}